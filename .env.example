# Create EmailOctopus API key at https://emailoctopus.com/api-documentation
EMAILOCTOPUS_API_KEY=
# List ID can be found in the URL as a UUID after clicking a list on https://emailoctopus.com/lists
# or the settings page of your list https://emailoctopus.com/lists/{UUID}/settings
EMAILOCTOPUS_LIST_ID=

# Create Beehiiv API key at https://developers.beehiiv.com/docs/v2/bktd9a7mxo67n-create-an-api-key
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# OPTIONAL — Enables Page Entity ID + category + about + fan_count in /tools/fb-info.
# Without this, the tool still works but only returns Actor ID (page-as-user).
#
# How to get an App Access Token (no user OAuth needed):
#   1. Create an FB App at https://developers.facebook.com/apps (type: Business or Other)
#   2. Settings → Basic → copy App ID + App Secret
#   3. Token format: <APP_ID>|<APP_SECRET>     (e.g. 1234567890|abcdef0123456789...)
#   4. Or generate one at https://developers.facebook.com/tools/accesstoken/
# Server-side only — Next.js does NOT bundle this into the browser bundle
# (no NEXT_PUBLIC_ prefix). Safe to keep here.
FB_GRAPH_TOKEN=
